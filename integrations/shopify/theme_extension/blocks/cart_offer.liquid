<div
  class="counterpilot-offer counterpilot-offer--cart"
  data-counterpilot-cart-offer
  data-counterpilot-visible="{{ block.settings.enabled }}"
>
  {% if block.settings.enabled %}
    <button type="button" class="counterpilot-offer__button" data-counterpilot-open>
      {{ block.settings.button_label }}
    </button>
    <form class="counterpilot-offer__form" data-counterpilot-form hidden>
      <label class="counterpilot-offer__label">
        Cart offer amount
        <input class="counterpilot-offer__input" name="offer_amount" inputmode="decimal" autocomplete="off">
      </label>
      <button type="submit" class="counterpilot-offer__submit">Submit offer</button>
    </form>
  {% endif %}
</div>

{% schema %}
{
  "name": "Cart Offer",
  "target": "section",
  "stylesheet": "counterpilot-offer.css",
  "javascript": "counterpilot-offer.js",
  "enabled_on": {
    "templates": ["cart"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Enable cart offer button",
      "default": false
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Make an offer on cart"
    }
  ]
}
{% endschema %}
